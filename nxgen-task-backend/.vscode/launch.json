{
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Debug API (Console Only)",
        "runtimeExecutable": "node",
        "runtimeArgs": ["--import", "tsx"],
        "program": "${workspaceFolder}/server.ts",
        "skipFiles": ["<node_internals>/**"],
        "console": "internalConsole",
        "internalConsoleOptions": "openOnSessionStart"
      }
    ]
  }